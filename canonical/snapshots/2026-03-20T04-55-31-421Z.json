{
  "spacing": {
    "scale": {
      "-50": {
        "$value": "clamp(2.48px, 0.1357vw + 2.0457px, 4px)",
        "$type": "fluid"
      },
      "-100": {
        "$value": "clamp(4.8px, 0.25vw + 4px, 8px)",
        "$type": "fluid"
      },
      "-150": {
        "$value": "clamp(7.12px, 0.3297vw + 6.0649px, 12px)",
        "$type": "fluid"
      },
      "-200": {
        "$value": "clamp(9.44px, 0.4432vw + 8.0216px, 16px)",
        "$type": "fluid"
      },
      "-250": {
        "$value": "clamp(11.76px, 0.515vw + 10.112px, 20px)",
        "$type": "fluid"
      },
      "-300": {
        "$value": "clamp(14.08px, 0.62vw + 12.096px, 24px)",
        "$type": "fluid"
      },
      "-400": {
        "$value": "clamp(18.4px, 0.6071vw + 16.4571px, 32px)",
        "$type": "fluid"
      },
      "-500": {
        "$value": "clamp(22.72px, 0.7714vw + 20.2514px, 40px)",
        "$type": "fluid"
      }
    },
    "component": {
      "xs": {
        "$value": "{spacing.scale.-50}",
        "$type": "number"
      },
      "sm": {
        "$value": "{spacing.scale.-100}",
        "$type": "number"
      },
      "md": {
        "$value": "{spacing.scale.-150}",
        "$type": "number"
      },
      "lg": {
        "$value": "{spacing.scale.-200}",
        "$type": "number"
      }
    },
    "layout": {
      "sm": {
        "$value": "{spacing.scale.-250}",
        "$type": "number"
      },
      "md": {
        "$value": "{spacing.scale.-300}",
        "$type": "number"
      },
      "lg": {
        "$value": "{spacing.scale.-400}",
        "$type": "number"
      },
      "xl": {
        "$value": "{spacing.scale.-500}",
        "$type": "number"
      }
    }
  },
