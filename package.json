{
  "name": "rei-cedar-token-pipeline-spike",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./meta/*": "./dist/themes/rei-dot-com/meta/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm tokens:build && pnpm storybook:build",
    "lint": "oxlint src",
    "format": "oxfmt --write src",
    "prepare": "husky",
    "commit": "cz",
    "sync:figma-to-tokens": "tsx src/sync/figma-to-tokens.ts",
    "sync:tokens-to-figma": "tsx src/sync/tokens-to-figma.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "build:package": "pnpm tokens:build",
    "release": "pnpm build:package && pnpm publish --access public",
    "tokens:platforms": "tsx style-dictionary/build.ts",
    "tokens:normalize": "tsx src/normalization/normalize.ts",
    "tokens:types:base": "tsx src/build/generate-base-types.ts",
    "tokens:sd": "tsx src/build/build-style-dictionary.ts",
    "tokens:build": "pnpm tokens:normalize && pnpm tokens:types:base && pnpm tokens:sd && pnpm tokens:platforms && pnpm postbuild:normalized",
    "postbuild:normalized": "tsx scripts/postbuild-normalized.js",
    "tokens:validate:normalized": "tsx scripts/validate-normalized-json.ts",
    "test:contract": "vitest run src/contract/canonical-contract.test.ts --reporter=verbose",
    "check:canonical": "pnpm tokens:normalize && pnpm test:contract",
    "tokens:snapshot": "tsx src/snapshot.ts",
    "diff:baseline": "pnpm tokens:normalize && pnpm tokens:snapshot baseline",
    "diff:current": "pnpm tokens:normalize && pnpm tokens:snapshot current",
    "test": "vitest run --reporter=verbose"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "src/**/*.ts": [
      "oxfmt --write",
      "oxlint"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@figma/rest-api-spec": "^0.36.0",
    "@storybook/html": "^10.2.15",
    "@storybook/html-vite": "^10.2.15",
    "@types/node": "^25.2.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "storybook": "^10.2.15",
    "style-dictionary": "^5.3.3",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
